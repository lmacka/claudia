{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "claudia Helm values",
  "description": "Schema for claudia Helm chart values. Single-tenant, single-user-per-deploy.",
  "type": "object",
  "required": ["displayName", "dob"],
  "properties": {
    "displayName": {
      "type": "string",
      "minLength": 1,
      "description": "How claudia addresses the user."
    },
    "dob": {
      "type": "string",
      "format": "date",
      "description": "ISO date. Age computed from this."
    },
    "country": {
      "type": "string",
      "default": "AU"
    },
    "theme": {
      "type": "string",
      "enum": ["sage", "blush", "lavender", "amber", "contrast"],
      "default": "sage"
    },
    "integrations": {
      "type": "object",
      "properties": {
        "google": {
          "type": "object",
          "description": "Gmail + Google Calendar tool integration. Opt-in; default off.",
          "properties": {
            "enabled": {
              "type": "boolean",
              "default": false
            },
            "secretRef": {
              "type": "object",
              "properties": {
                "name": { "type": "string" },
                "clientIdKey": { "type": "string", "default": "client-id" },
                "clientSecretKey": { "type": "string", "default": "client-secret" }
              }
            }
          }
        }
      }
    },
    "anthropicSecretRef": {
      "type": "object",
      "required": ["name", "key"]
    },
    "basicAuth": {
      "type": "object",
      "required": ["passwordSecretRef"]
    },
    "model": {
      "type": "object",
      "properties": {
        "primary": { "type": "string", "default": "claude-sonnet-4-6" }
      }
    },
    "pvc": {
      "type": "object",
      "properties": {
        "size": { "type": "string", "default": "10Gi" },
        "storageClassName": { "type": "string" }
      }
    },
    "ingress": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean", "default": true },
        "host": { "type": "string", "minLength": 1 },
        "className": { "type": "string" },
        "tls": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean", "default": true },
            "secretName": { "type": "string" }
          }
        }
      }
    }
  }
}
